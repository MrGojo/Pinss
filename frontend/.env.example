# Local dev: FastAPI (no trailing slash)
REACT_APP_BACKEND_URL=http://127.0.0.1:8000

# Split deploy (Vercel/Netlify): set to your API public URL, e.g. https://pinterest-api.onrender.com
# Must match what you set before `yarn build` — this value is baked into the JS at build time.

# Docker same-origin: leave empty so the app uses /api on the same host
