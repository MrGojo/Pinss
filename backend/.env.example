# Copy to .env and fill in values. Never commit .env.

# MongoDB — OPTIONAL. Leave MONGO_URL unset (or empty) for "no database" mode:
# each generation is held in server memory + files until you download or the server evicts old sessions.
# MONGO_URL=mongodb://localhost:27017
# DB_NAME=pinterest_pins

# Google Gemini (AI pin backgrounds)
GEMINI_API_KEY=

# Split deploy (Vercel/Netlify + this API): set to your real frontend origin(s), no spaces.
# Example: https://your-app.vercel.app,https://www.yourdomain.com
# Use * only for quick tests (not recommended with credentials).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# How many recent generations to keep in memory when MONGO_URL is unset (oldest deleted).
# MAX_EPHEMERAL_SESSIONS=40

# Optional: serve React build from this folder (full-stack Docker only)
# FRONTEND_STATIC_DIR=
