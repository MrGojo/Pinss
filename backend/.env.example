# Copy to .env and fill in values. Never commit .env.

# MongoDB (Atlas connection string or local)
MONGO_URL=mongodb://localhost:27017
DB_NAME=pinterest_pins

# Google Gemini (pin image generation)
GEMINI_API_KEY=

# Comma-separated origins for browser CORS, or * for allow-all (dev only)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: serve React build from this folder (set automatically in Docker)
# FRONTEND_STATIC_DIR=
